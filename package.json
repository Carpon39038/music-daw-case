{
  "name": "music-daw-case",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.4.1",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "pretest:e2e": "pnpm run build",
    "test:e2e": "playwright test",
    "preview": "vite preview",
    "verify:preflight": "pnpm run lint && pnpm run test && pnpm run build",
    "verify:full": "pnpm run verify:preflight && pnpm run test:e2e",
    "verify:ci": "pnpm run verify:full && pnpm run harness:loop -- --task verify-$(date +%F)",
    "harness:eval": "node scripts/eval.mjs",
    "harness:govern": "node scripts/govern.mjs",
    "harness:aggregate": "node scripts/aggregate.mjs",
    "harness:weekly": "node scripts/weekly-report.mjs",
    "harness:next-plan": "node scripts/next-plan.mjs",
    "harness:task-pack": "node scripts/task-pack.mjs",
    "harness:judge": "node scripts/judge.mjs",
    "harness:loop": "node scripts/run-loop.mjs",
    "harness:gated": "node scripts/harness-gated-run.mjs",
    "test:e2e:flaky": "playwright test --repeat-each=3 --retries=0"
  },
  "dependencies": {
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zundo": "^2.3.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.2"
  }
}
